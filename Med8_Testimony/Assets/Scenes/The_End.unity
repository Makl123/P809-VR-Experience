  m_Script: {fileID: 11500000, guid: fdd2a3af290314344b7f0980bec2a1de, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Endscreen
  dialogueText: {fileID: 1931569135}
  messages:
  - "Right now, there are people around the world, who are punished for what type
    of clothing they wear and how they wear it. \r\n"
  - "For some, wearing a piece of clothing differently is something that most people
    won\u2019t even notice, but in some countries, this can lead to fines and imprisonment."
  - 'This experience was inspired by the systemic oppression of women in Iran, but
    it can happen in many places in various forms. '
  - 'Created by:

    Alba Simonsen

    Alfred Villiam Thorlaksen

    Daniel Eyong
    Agbor

    Maria Malgorzata Klis

    Michael Holst

    Oliver Jul Westerman

'
  - 'Voice Acting:

    Alba Simonsen

    Maria Malgorzata Klis

    Michael Holst


'
  - 'Assets done by:

    Alba Simonsen

    Daniel Eyong Agbor

    Maria Malgorzata
    Klis

    Oliver Jul Westerman


'
  visibleDurations:
  - 6
  - 8
  - 7
  - 4
  - 4
  - 4
  fadeDuration: 1
  defaultVisibleDuration: 4
  triggerOnMessageIndex: 3
  objectsToActivate:
